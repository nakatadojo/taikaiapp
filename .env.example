# PostgreSQL connection string (Railway provides this automatically)
DATABASE_URL=postgresql://user:password@host:5432/tournament

# JWT Configuration
JWT_SECRET=your-jwt-secret-here-min-32-chars-generate-with-node-e-crypto
JWT_EXPIRY=24h

# Resend Email Service (https://resend.com)
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=noreply@yourdomain.com

# Application URL (used in email links)
APP_URL=http://localhost:3000

# Cloudflare R2 Storage (optional — falls back to local uploads/ in dev)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=tournament-uploads
R2_PUBLIC_URL=

# Server
NODE_ENV=development
PORT=3000
